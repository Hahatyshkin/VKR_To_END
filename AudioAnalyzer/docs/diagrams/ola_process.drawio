          <mxGeometry x="1030" y="108" width="60" height="25" as="geometry" />
        </mxCell>
        
        <!-- Секция 1: Зачем нужен OLA -->
        <mxCell id="why_title" value="1. ЗАЧЕМ НУЖЕН МЕТОД OLA?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontFamily=Times New Roman;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="why_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="400" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="why_text" value="ПРОБЛЕМА: Преобразования (FFT, DCT, DWT, FWHT)&#xa;работают только с блоками фиксированной длины.&#xa;&#xa;РЕШЕНИЕ: OLA разбивает сигнал на перекрывающиеся&#xa;блоки, обрабатывает каждый, затем собирает обратно.&#xa;&#xa;РЕЗУЛЬТАТ: Можно обрабатывать сигналы любой длины." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="50" y="115" width="380" height="90" as="geometry" />
        </mxCell>
        
        <!-- Секция 2: Параметры OLA -->
        <mxCell id="params_title" value="2. ПАРАМЕТРЫ OLA" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontFamily=Times New Roman;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="200" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="params_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="470" y="110" width="450" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="params_table" value="Параметр           Значение         Описание&#xa;─────────────────────────────────────────────────&#xa;block_size (N)     2048             Размер блока (степень 2)&#xa;hop_size (H)       N/2 = 1024       Шаг (50% перекрытие)&#xa;window             sqrt-Hann        Окно анализа/синтеза&#xa;n_frames           (L-N)/H + 1      Число фреймов" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="480" y="115" width="430" height="90" as="geometry" />
        </mxCell>
        
        <!-- Секция 3: Схема процесса -->
        <mxCell id="process_title" value="3. СХЕМА ПРОЦЕССА OLA" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontFamily=Times New Roman;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Начало -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="90" y="270" width="30" height="30" as="geometry" />
        </mxCell>
        
        <!-- Входной сигнал -->
        <mxCell id="input" value="Входной сигнал&#xa;x[n], n=0...L-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="130" height="50" as="geometry" />
        </mxCell>
        
        <!-- Разбиение -->
        <mxCell id="split" value="Разбиение на&#xa;фреймы&#xa;(50% overlap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="130" height="60" as="geometry" />
        </mxCell>
        
        <!-- Цикл -->
        <mxCell id="loop" value="Для каждого&#xa;фрейма i?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="130" height="70" as="geometry" />
        </mxCell>
        
        <!-- Окно -->
        <mxCell id="window" value="Применение&#xa;окна sqrt-Hann" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="220" y="505" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Преобразование -->
        <mxCell id="transform" value="Прямое&#xa;преобразование&#xa;(FFT/DCT/DWT/FWHT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="360" y="495" width="120" height="70" as="geometry" />
        </mxCell>
        
        <!-- Обработка -->
        <mxCell id="process_coeff" value="Отбор&#xa;коэффициентов&#xa;(опционально)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="510" y="495" width="110" height="70" as="geometry" />
        </mxCell>
        
        <!-- Обратное -->
        <mxCell id="inverse" value="Обратное&#xa;преобразование" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="650" y="505" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Накопление -->
        <mxCell id="accumulate" value="Накопление&#xa;y_accum += rec&#xa;w_accum += w²" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="650" y="590" width="110" height="60" as="geometry" />
        </mxCell>
        
        <!-- Нормировка -->
        <mxCell id="normalize" value="Нормировка:&#xa;y = y_accum / w_accum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="130" height="50" as="geometry" />
