          <mxGeometry x="100" y="80" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="wav_props" value="Преимущества:&#xa;• Без сжатия (lossless)&#xa;• Простая структура&#xa;• Высокая скрытность LSB&#xa;&#xa;Недостатки:&#xa;• Большой размер файла&#xa;• Заметные изменения при LSB" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=top;align=left" vertex="1" parent="1">
