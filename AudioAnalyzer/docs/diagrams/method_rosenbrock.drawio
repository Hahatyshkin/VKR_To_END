<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2025-03-12T00:00:00.000Z" agent="Draw.io" version="22.1.0" type="device">
  <diagram id="rosenbrock-method" name="Rosenbrock-like - Нелинейное сглаживание">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="Rosenbrock-like (Нелинейное сглаживание)&#xa;Мягкая компрессия динамики сигнала" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="50" as="geometry" />
        </mxCell>
        
        <!-- Секция: Идея метода -->
        <mxCell id="idea_title" value="💡 Идея метода (простыми словами)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="500" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_text" value="Представьте &quot;мягкий ограничитель&quot; сигнала:&#xa;&#xa;• Сигналы около нуля проходят почти без изменений&#xa;• Сигналы слишком громкие — мягко ослабляются&#xa;&#xa;Аналогия: как автоматическая регулировка громкости,&#xa;которая не даёт звукам быть слишком громкими,&#xa;но сохраняет естественность тихих звуков.&#xa;&#xa;Назван в честь функции Розенброка из оптимизации." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="480" height="120" as="geometry" />
        </mxCell>
        
        <!-- Схема работы -->
        <mxCell id="scheme_title" value="⚙️ Как работает Rosenbrock-like" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Вход -->
        <mxCell id="input" value="Входной&#xa;сигнал x[n]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Нелинейное преобразование -->
        <mxCell id="transform" value="Нелинейное&#xa;преобразование&#xa;y = x/(1+α(x-β)²)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="160" y="285" width="120" height="80" as="geometry" />
        </mxCell>
        
        <!-- Нормировка -->
        <mxCell id="norm" value="Нормировка&#xa;пика" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="320" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Выход -->
        <mxCell id="output" value="Восстановленный&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="300" width="90" height="50" as="geometry" />
        </mxCell>
        
        <!-- MP3 -->
        <mxCell id="mp3" value="Кодирование&#xa;в MP3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="380" width="90" height="50" as="geometry" />
        </mxCell>
        
        <!-- Стрелки -->
        <mxCell id="arr1" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="input" target="transform">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr2" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="transform" target="norm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr3" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="norm" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr4" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="output" target="mp3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Математика -->
        <mxCell id="math_title" value="📐 Математическая формула" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="math_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="500" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="math_text" value="y = x / (1 + α·(x - β)²)&#xa;&#xa;где:&#xa;  α (alpha) — параметр сглаживания [0...10]&#xa;  β (beta)  — точка перегиба [-5...5]&#xa;&#xa;При x = β: y = x (сигнал проходит без изменений)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="495" width="480" height="90" as="geometry" />
        </mxCell>
        
        <!-- Преимущества -->
        <mxCell id="pros_title" value="✅ Преимущества" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="450" height="140" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_text" value="🎵 Мягкая компрессия:&#xa;   • Нет жёсткого ограничения (как hard clipping)&#xa;   • Естественное звучание&#xa;&#xa;⚡ Вычислительная простота:&#xa;   • O(N) — линейная сложность&#xa;   • Минимум операций&#xa;&#xa;🎛️ Гибкость:&#xa;   • Два параметра для настройки&#xa;   • Можно адаптировать под тип сигнала" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="135" width="430" height="130" as="geometry" />
        </mxCell>
        
        <!-- Недостатки -->
        <mxCell id="cons_title" value="⚠️ Недостатки" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="290" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="320" width="450" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_text" value="❓ Эвристический метод:&#xa;   • Нет теоретического обоснования оптимальности&#xa;   • Экспериментальный подход&#xa;&#xa;⚠️ Искажения:&#xa;   • Вносит нелинейные искажения&#xa;   • Необратимое преобразование&#xa;&#xa;📊 Не спектральный метод:&#xa;   • Не анализирует частоты&#xa;   • Работает только во временной области" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="325" width="430" height="120" as="geometry" />
        </mxCell>
        
        <!-- Параметры -->
        <mxCell id="params_title" value="⚙️ Параметры и их влияние" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="470" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="params_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="450" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="params_text" value="α (alpha) — интенсивность сглаживания:&#xa;   • α = 0: сигнал без изменений (линейный)&#xa;   • α = 0.2: мягкое сглаживание (по умолчанию)&#xa;   • α > 1: сильная компрессия&#xa;&#xa;β (beta) — точка перегиба:&#xa;   • β = 1.0: перегиб на границе (по умолчанию)&#xa;   • β = 0.5: больше искажений громких звуков&#xa;   • β = 0.0: искажения симметричны относительно 0" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="505" width="430" height="110" as="geometry" />
        </mxCell>
        
        <!-- График характеристики -->
        <mxCell id="graph_title" value="📈 Характеристика Rosenbrock-like" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="250" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="graph_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="300" height="190" as="geometry" />
        </mxCell>
        
        <!-- Оси -->
        <mxCell id="axis_x" value="" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#333333" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="810" as="sourcePoint" />
            <mxPoint x="320" y="810" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="axis_y" value="" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#333333" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="810" as="sourcePoint" />
            <mxPoint x="70" y="660" as="targetPoint" />
          </mxGeometry>
