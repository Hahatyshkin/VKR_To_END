<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2025-03-12T00:00:00.000Z" agent="Draw.io" version="22.1.0" type="device">
  <diagram id="huffman-method" name="Huffman-like - μ-law компандирование">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="Huffman-like (μ-law компандирование)&#xa;Нелинейное сжатие динамического диапазона" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="50" as="geometry" />
        </mxCell>
        
        <!-- Секция: Идея метода -->
        <mxCell id="idea_title" value="💡 Идея метода (простыми словами)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="500" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_text" value="Человеческое ухо слышит тихие звуки менее точно, чем громкие.&#xa;&#xa;μ-law использует это:&#xa;• Тихие звуки — усиливаются (больше деталей)&#xa;• Громкие звуки — сжимаются (меньше деталей)&#xa;&#xa;Аналогия: логарифмическая шкала громкости&#xa;Как если бы мы дали &quot;больше места&quot; для тихих звуков&#xa;и &quot;меньше места&quot; для громких." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="480" height="120" as="geometry" />
        </mxCell>
        
        <!-- Схема работы -->
        <mxCell id="scheme_title" value="⚙️ Как работает Huffman-like" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Вход -->
        <mxCell id="input" value="Входной&#xa;сигнал x[n]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- μ-law компрессия -->
        <mxCell id="compress" value="μ-law&#xa;компрессия&#xa;y = log(1+μ|x|)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="290" width="90" height="70" as="geometry" />
        </mxCell>
        
        <!-- Квантование -->
        <mxCell id="quant" value="Квантование&#xa;bits=8&#xa;(2^8=256 уровней)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="270" y="290" width="100" height="70" as="geometry" />
        </mxCell>
        
        <!-- Обратное квантование -->
        <mxCell id="dequant" value="Обратное&#xa;квантование" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="270" y="390" width="100" height="50" as="geometry" />
        </mxCell>
        
        <!-- μ-law экспандирование -->
        <mxCell id="expand" value="μ-law&#xa;экспандирование&#xa;x = ((1+μ)^|y|-1)/μ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="385" width="90" height="60" as="geometry" />
        </mxCell>
        
        <!-- Выход -->
        <mxCell id="output" value="Восстановленный&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- MP3 -->
        <mxCell id="mp3" value="MP3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="400" y="400" width="60" height="40" as="geometry" />
        </mxCell>
        
        <!-- Стрелки -->
        <mxCell id="arr1" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="input" target="compress">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr2" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="compress" target="quant">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr3" style="endArrow=classic;html=1;strokeWidth=2;dashed=1" edge="1" parent="1" source="quant" target="dequant">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr4" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="dequant" target="expand">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr5" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="expand" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr6" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="output" target="mp3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Математика -->
        <mxCell id="math_title" value="📐 Математическая формула" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="math_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="500" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="math_text" value="Компрессия:  y = sign(x) · ln(1 + μ·|x|) / ln(1 + μ)&#xa;&#xa;Экспандирование:  x = sign(y) · ((1 + μ)^|y| - 1) / μ&#xa;&#xa;Стандарт: μ = 255 (телефония США/Японии)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="515" width="480" height="90" as="geometry" />
        </mxCell>
        
        <!-- Преимущества -->
        <mxCell id="pros_title" value="✅ Преимущества" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="450" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_text" value="👂 Соответствует восприятию человека:&#xa;   • Логарифмическая чувствительность уха&#xa;   • Больше деталей для тихих звуков&#xa;&#xa;📊 Сжатие динамического диапазона:&#xa;   • Уменьшение битовой глубины без потери качества&#xa;   • 8 бит с μ-law ≈ 12-14 бит линейных&#xa;&#xa;🏆 Промышленный стандарт:&#xa;   • Телефония (G.711)&#xa;   • Цифровая связь" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="135" width="430" height="140" as="geometry" />
        </mxCell>
        
        <!-- Недостатки -->
        <mxCell id="cons_title" value="⚠️ Недостатки" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="450" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_text" value="📉 Потери при квантовании:&#xa;   • Необратимое преобразование&#xa;   • Шум квантования&#xa;&#xa;🔢 Ограниченное разрешение:&#xa;   • При bits=8 — только 256 уровней&#xa;&#xa;⚠️ Не спектральный метод:&#xa;   • Не анализирует частоты" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="335" width="430" height="120" as="geometry" />
        </mxCell>
        
        <!-- Параметры -->
        <mxCell id="params_title" value="⚙️ Параметры" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="480" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="params_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="510" width="450" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="params_text" value="μ (mu) — параметр компрессии [1...∞]&#xa;   • По умолчанию: 255 (стандарт G.711)&#xa;   • Чем больше μ, тем сильнее компрессия&#xa;&#xa;bits — битовая глубина квантования [1...16]&#xa;   • По умолчанию: 8 бит (256 уровней)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="515" width="430" height="90" as="geometry" />
        </mxCell>
        
        <!-- График характеристики -->
        <mxCell id="graph_title" value="📈 Характеристика μ-law" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="graph_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="300" height="180" as="geometry" />
        </mxCell>
        
        <!-- Оси -->
        <mxCell id="axis_x" value="" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#333333" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="800" as="sourcePoint" />
            <mxPoint x="320" y="800" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="axis_y" value="" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#333333" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="800" as="sourcePoint" />
            <mxPoint x="70" y="670" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="x_label" value="Вход x" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="280" y="805" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="y_label" value="Выход y" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="50" y="655" width="50" height="20" as="geometry" />
        </mxCell>
        
        <!-- Линейная (для сравнения) -->
        <mxCell id="linear" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="800" as="sourcePoint" />
            <mxPoint x="300" y="690" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- μ-law кривая -->
        <mxCell id="mulaw_curve" value="" style="curved=1;endArrow=none;html=1;strokeWidth=2;strokeColor=#1a73e8" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="800" as="sourcePoint" />
            <mxPoint x="300" y="690" as="targetPoint" />
            <Array as="points">
              <mxPoint x="100" y="760" />
              <mxPoint x="150" y="730" />
              <mxPoint x="200" y="715" />
              <mxPoint x="250" y="700" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="linear_label" value="линейная" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#999999" vertex="1" parent="1">
          <mxGeometry x="230" y="770" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mulaw_label" value="μ-law" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#1a73e8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="715" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- Применение -->
        <mxCell id="use_title" value="🎯 Где применять" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="630" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="use_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="660" width="450" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="use_text" value="• Предобработка для энтропийного кодирования&#xa;• Сжатие голоса и речи&#xa;• Системы связи с ограниченной пропускной способностью" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="665" width="430" height="70" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
