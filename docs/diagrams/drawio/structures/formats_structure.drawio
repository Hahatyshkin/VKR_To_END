          <mxGeometry x="400" y="80" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="mp3_props" value="Преимущества:&#xa;• Компактный размер&#xa;• Широкое распространение&#xa;• Сложно обнаружить&#xa;&#xa;Недостатки:&#xa;• Сжатие с потерями&#xa;• Ограниченная ёмкость" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;align=left" vertex="1" parent="1">
