<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2025-03-12T00:00:00.000Z" agent="Draw.io" version="22.1.0" type="device">
  <diagram id="metrics-calculation" name="Расчёт метрик качества">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips=1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="РАСЧЁТ МЕТРИК КАЧЕСТВА АУДИО&#xa;Сравнение оригинала и обработанного сигнала" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="50" as="geometry" />
        </mxCell>
        
        <!-- ==================== ВХОДНЫЕ ДАННЫЕ ==================== -->
        <mxCell id="input_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="input_title" value="ВХОДНЫЕ ДАННЫЕ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="50" y="85" width="200" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="ref_data" value="Референс (оригинал):&#xa;ref[n] — PCM float32&#xa;sr_ref — частота дискретизации&#xa;len = N отсчётов" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;fontFamily=Times New Roman;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="200" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="test_data" value="Тест (обработанный):&#xa;test[n] — PCM float32&#xa;sr_test — частота дискретизации&#xa;len = M отсчётов" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;fontFamily=Times New Roman;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="280" y="110" width="200" height="60" as="geometry" />
        </mxCell>
        
        <!-- ==================== ПРЕДОБРАБОТКА ==================== -->
        <mxCell id="preproc_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="preproc_title" value="ПРЕДВАРИТЕЛЬНАЯ ОБРАБОТКА" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="50" y="205" width="300" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="resample" value="1. Ресемплирование&#xa;test → sr_ref&#xa;(линейная интерполяция)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=9;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="140" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="align" value="2. Выравнивание длины&#xa;N = min(len(ref), len(test))&#xa;ref = ref[:N], test = test[:N]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=9;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="220" y="230" width="150" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="preproc_result" value="ref[n], test[n]&#xa;n = 0...N-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="390" y="230" width="100" height="45" as="geometry" />
        </mxCell>
        
        <!-- ==================== МЕТРИКИ ВРЕМЕННОЙ ОБЛАСТИ ==================== -->
        <mxCell id="time_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="500" height="220" as="geometry" />
        </mxCell>
        <mxCell id="time_title" value="МЕТРИКИ ВРЕМЕННОЙ ОБЛАСТИ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="50" y="305" width="350" height="20" as="geometry" />
        </mxCell>
        
        <!-- SNR -->
        <mxCell id="snr_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="snr_name" value="SNR (Signal-to-Noise Ratio)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="70" y="335" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="snr_formula" value="SNR = 10·log₁₀(P_sig / P_noise)&#xa;P_sig = mean(ref²)&#xa;P_noise = mean((ref - test)²)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="70" y="355" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="snr_interp" value="↑ лучше" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#0d652d;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="230" y="355" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- RMSE -->
        <mxCell id="rmse_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="290" y="330" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rmse_name" value="RMSE (Root Mean Square Error)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="300" y="335" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="rmse_formula" value="RMSE = √(mean((ref - test)²))&#xa;&#xa;Среднеквадратичная ошибка&#xa;во временной области" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="300" y="355" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rmse_interp" value="↓ лучше" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="460" y="355" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- SI-SDR -->
        <mxCell id="sisdr_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="450" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sisdr_name" value="SI-SDR (Scale-Invariant Signal-to-Distortion Ratio)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="70" y="425" width="350" height="15" as="geometry" />
        </mxCell>
        <mxCell id="sisdr_formula" value="α = &lt;ref, test&gt; / ||ref||²           — масштаб&#xa;y_target = α · ref                   — целевой компонент&#xa;e_noise = test - y_target            — шум&#xa;SI-SDR = 10·log₁₀(||y_target||² / ||e_noise||²)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="70" y="445" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sisdr_interp" value="↑ лучше&#xa;Инвариантен к масштабу" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#0d652d;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="430" y="455" width="70" height="30" as="geometry" />
        </mxCell>
        
        <!-- ==================== МЕТРИКИ СПЕКТРАЛЬНОЙ ОБЛАСТИ ==================== -->
        <mxCell id="spec_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="550" height="320" as="geometry" />
        </mxCell>
        <mxCell id="spec_title" value="МЕТРИКИ СПЕКТРАЛЬНОЙ ОБЛАСТИ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="570" y="85" width="350" height="20" as="geometry" />
        </mxCell>
        
        <!-- Общий шаг FFT -->
        <mxCell id="fft_step" value="Общий шаг: для каждого окна (n_fft=1024, hop=512):&#xa;R = |rFFT(ref_window)|, T = |rFFT(test_window)|" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=9;fontFamily=Times New Roman;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="580" y="110" width="510" height="35" as="geometry" />
        </mxCell>
        
        <!-- LSD -->
        <mxCell id="lsd_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="580" y="155" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lsd_name" value="LSD (Log-Spectral Distance)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="590" y="160" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="lsd_formula" value="S_R = 20·log₁₀(|R|)&#xa;S_T = 20·log₁₀(|T|)&#xa;LSD = mean(√(mean((S_R - S_T)²)))" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="590" y="180" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lsd_interp" value="↓ лучше" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="175" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- Spectral Convergence -->
        <mxCell id="sc_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="840" y="155" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sc_name" value="Spectral Convergence" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="850" y="160" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="sc_formula" value="SC = |||R| - |T|||₂ / ||R||₂&#xa;&#xa;Нормированная ошибка&#xa;амплитудных спектров" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="850" y="180" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc_interp" value="↓ лучше" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1040" y="175" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- Centroid -->
        <mxCell id="centroid_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="580" y="245" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="centroid_name" value="Spectral Centroid Δ (Гц)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="590" y="250" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="centroid_formula" value="centroid = Σ(k·|X_k|) / Σ|X_k| × (sr/N)&#xa;&#xa;Δ = mean(|centroid_R - centroid_T|)&#xa;«Центр тяжести» спектра" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="590" y="270" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="centroid_interp" value="↓ лучше" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="265" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- Cosine -->
        <mxCell id="cos_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="840" y="245" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cos_name" value="Cosine Similarity" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="850" y="250" width="200" height="15" as="geometry" />
        </mxCell>
        <mxCell id="cos_formula" value="CosSim = &lt;R, T&gt; / (||R||·||T||)&#xa;&#xa;Косинус угла между&#xa;спектральными векторами" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=5;spacingTop=3" vertex="1" parent="1">
          <mxGeometry x="850" y="270" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cos_interp" value="↑ лучше&#xa;(0..1)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#0d652d;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1035" y="265" width="50" height="25" as="geometry" />
        </mxCell>
        
        <!-- Дополнительно -->
        <mxCell id="spec_note" value="Все спектральные метрики усредняются по всем окнам сигнала" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Times New Roman;fontColor=#666666;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="580" y="330" width="510" height="20" as="geometry" />
        </mxCell>
        
        <!-- ==================== АГРЕГИРОВАННЫЙ БАЛЛ ==================== -->
        <mxCell id="score_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="550" height="200" as="geometry" />
        </mxCell>
        <mxCell id="score_title" value="АГРЕГИРОВАННЫЙ БАЛЛ (Score)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="570" y="425" width="300" height="20" as="geometry" />
        </mxCell>
        
        <!-- Min-Max нормировка -->
        <mxCell id="norm_title" value="Шаг 1: Min-Max нормировка по всем методам" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="580" y="450" width="300" height="15" as="geometry" />
        </mxCell>
        
        <mxCell id="norm_formula" value="Для метрик «ниже-лучше» (LSD, SC, RMSE, CentroidΔ, time):&#xa;   norm = (max - value) / (max - min)&#xa;&#xa;Для метрик «выше-лучше» (SNR, SI-SDR, CosSim):&#xa;   norm = (value - min) / (max - min)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="580" y="465" width="500" height="60" as="geometry" />
        </mxCell>
        
        <!-- Взвешенная сумма -->
        <mxCell id="weight_title" value="Шаг 2: Взвешенная сумма" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="580" y="530" width="300" height="15" as="geometry" />
        </mxCell>
        
        <mxCell id="weight_formula" value="score = 0.20·LSD_n + 0.15·SC_n + 0.20·SNR_n + 0.15·RMSE_n&#xa;       + 0.15·SI-SDR_n + 0.05·CentroidΔ_n + 0.05·CosSim_n + 0.05·time_n" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="580" y="545" width="520" height="35" as="geometry" />
        </mxCell>
        
        <!-- Интерпретация -->
        <mxCell id="score_interp" value="Интерпретация: score → 1.0 — лучший метод, score → 0.0 — худший метод" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Times New Roman;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="580" y="585" width="500" height="20" as="geometry" />
        </mxCell>
        
        <!-- ==================== ТАБЛИЦА СВОДКИ ==================== -->
        <mxCell id="summary_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="summary_title" value="СВОДНАЯ ТАБЛИЦА МЕТРИК" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontFamily=Times New Roman;fontColor=#666666" vertex="1" parent="1">
          <mxGeometry x="50" y="545" width="300" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="summary_table" value="Метрика              Направление      Вес      Область&#xa;─────────────────────────────────────────────────&#xa;LSD (дБ)               ↓ лучше         20%      Спектр&#xa;SNR (дБ)               ↑ лучше         20%      Время&#xa;RMSE                     ↓ лучше         15%      Время&#xa;SI-SDR (дБ)          ↑ лучше         15%      Время&#xa;Spectral Conv.      ↓ лучше         15%      Спектр&#xa;Centroid Δ (Гц)     ↓ лучше          5%      Спектр&#xa;Cosine Sim.          ↑ лучше          5%      Спектр&#xa;Time (с)               ↓ лучше          5%      —" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontFamily=Courier New;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="570" width="480" height="160" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
