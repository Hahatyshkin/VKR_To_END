        <!-- Advantages Box -->
        <mxCell id="adv" value="Преимущества FWHT на FPGA:&#xa;• Только сложение и вычитание (нет умножителей)&#xa;• В 3-5 раз меньше логических элементов чем FFT&#xa;• Время выполнения: N·log₂N тактов&#xa;• Подходит для IoT и носимых устройств" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="320" height="100" as="geometry" />
        </mxCell>
        <!-- Comparison Box -->
        <mxCell id="comp" value="Сравнение ресурсов FPGA:&#xa;┌────────────────┬─────────┬─────────┐&#xa;│    Ресурс      │   FFT   │  FWHT   │&#xa;├────────────────┼─────────┼─────────┤&#xa;│ Умножители     │  N·log₂N│    0    │&#xa;│ LUT (логика)   │   Высок.│  Низк.  │&#xa;│ Потребление    │   Высок.│  Низк.  │&#xa;│ Задержка       │ Средняя │ Низкая  │&#xa;└────────────────┴─────────┴─────────┘" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;rounded=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="400" y="300" width="280" height="140" as="geometry" />
        </mxCell>
        <!-- Application domains -->
        <mxCell id="apps" value="Области применения:&#xa;• Стеганография аудиосигналов&#xa;• Предобработка для ML на edge-устройствах&#xa;• Сжатие в системах IoT&#xa;• Низкоэнергетические аудиосистемы" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
