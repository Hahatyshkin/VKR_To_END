        <!-- α=0.2 кривая -->
        <mxCell id="curve_02" value="" style="curved=1;endArrow=none;html=1;strokeWidth=2;strokeColor=#1a73e8" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="810" as="sourcePoint" />
