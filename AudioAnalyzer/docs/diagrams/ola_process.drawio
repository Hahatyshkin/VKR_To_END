            <mxPoint x="345" y="465" as="sourcePoint" />
            <mxPoint x="420" y="465" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Объяснение -->
        <mxCell id="viz_explain" value="Перекрытие 50%: каждый отсчёт принадлежит двум блокам&#xa;Синие зоны — области перекрытия (усредняются при сборке)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Times New Roman;fontColor=#666666" vertex="1" parent="1">
          <mxGeometry x="300" y="480" width="400" height="30" as="geometry" />
        </mxCell>
        
        <!-- Секция 5: Идеальная реконструкция -->
        <mxCell id="recon_title" value="5. УСЛОВИЕ ИДЕАЛЬНОЙ РЕКОНСТРУКЦИИ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontFamily=Times New Roman;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="800" y="270" width="350" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="recon_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="800" y="300" width="350" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="recon_text" value="При использовании sqrt-Hann окна с 50% перекрытием:&#xa;&#xa;     w²[n] + w²[n + N/2] = 1   для всех n&#xa;&#xa;Это обеспечивает идеальную реконструкцию&#xa;при отсутствии отбора коэффициентов.&#xa;&#xa;Окно: w[n] = √(Hann(n)) = √(0.5·(1 - cos(2πn/N)))" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;spacingTop=10;fontFamily=Times New Roman" vertex="1" parent="1">
          <mxGeometry x="810" y="305" width="330" height="110" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
