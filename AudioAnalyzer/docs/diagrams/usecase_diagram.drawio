        <!-- ===== СПЕЦИФИКАЦИЯ USE CASES ===== -->
        
        <mxCell id="spec_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
