<mxfile host="app.diagrams.net" modified="2026-04-06T12:00:00.000Z" agent="Super Z" version="21.0.0" type="device">
  <diagram name="Статистическая обработка" id="stats-flow">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- Title -->
        <mxCell id="title" value="Процесс статистической обработки результатов" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1a1a1a" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="450" height="30" as="geometry"/>
        </mxCell>
        
        <!-- Step 1: Data Collection -->
        <mxCell id="step1" value="1. Сбор данных&#xa;&#xa;Результаты измерений&#xa;для каждого метода:&#xa;• SNR, SI-SDR, LSD&#xa;• STOI, PESQ, MOS&#xa;• Время обработки" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="180" height="140" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 1-2 -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6c8ebf;endArrow=block;endFill=1" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Step 2: Descriptive Statistics -->
        <mxCell id="step2" value="2. Описательная статистика&#xa;&#xa;Для каждой метрики:&#xa;• Среднее: μ = Σxᵢ/n&#xa;• СКО: σ = √(Σ(xᵢ-μ)²/n)&#xa;• Медиана, мода" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="250" y="80" width="180" height="140" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 2-3 -->
        <mxCell id="arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#d6b656;endArrow=block;endFill=1" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Step 3: Confidence Intervals -->
        <mxCell id="step3" value="3. Доверительные интервалы&#xa;&#xa;95% CI:&#xa;μ ± t₀.₉₅ · (σ/√n)&#xa;&#xa;где t₀.₉₅ — критическое&#xa;значение Стьюдента" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="180" height="140" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 3-4 -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=block;endFill=1" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Step 4: Comparison -->
        <mxCell id="step4" value="4. Сравнение методов&#xa;&#xa;• t-критерий Стьюдента&#xa;• p-value &lt; 0.05&#xa;• ANOVA для групп&#xa;• Ранжирование" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="670" y="80" width="180" height="140" as="geometry"/>
        </mxCell>
        
        <!-- Step 5: Correlation Analysis -->
        <mxCell id="step5" value="5. Корреляционный анализ&#xa;&#xa;Матрица корреляций:&#xa;r = Σ(xᵢ-x̄)(yᵢ-ȳ) /&#xa;    √[Σ(xᵢ-x̄)²·Σ(yᵢ-ȳ)²]&#xa;&#xa;• r &gt; 0.7 — сильная связь&#xa;• r &lt; 0.3 — слабая связь" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="180" height="160" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 4-5 -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673a6;endArrow=block;endFill=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="250"/>
              <mxPoint x="130" y="250"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Step 6: Genre Analysis -->
        <mxCell id="step6" value="6. Анализ по жанрам&#xa;&#xa;Разделение выборки:&#xa;• 16 жанровых категорий&#xa;• Сравнение SNR, SI-SDR&#xa;• Выявление закономерностей&#xa;• Оптимальные методы" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="250" y="280" width="180" height="160" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 5-6 -->
        <mxCell id="arrow5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;endArrow=block;endFill=1" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Step 7: Visualization -->
        <mxCell id="step7" value="7. Визуализация&#xa;&#xa;• Диаграммы сравнения&#xa;• Радарные диаграммы&#xa;• Графики с CI&#xa;• Тепловые карты&#xa;• Box plots" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="460" y="280" width="180" height="160" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 6-7 -->
        <mxCell id="arrow6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=block;endFill=1" edge="1" parent="1" source="step6" target="step7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Step 8: Recommendations -->
        <mxCell id="step8" value="8. Рекомендации&#xa;&#xa;Формирование выводов:&#xa;• Оптимальный метод&#xa;• Условия применения&#xa;• Ограничения&#xa;• Направления развития" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="670" y="280" width="180" height="160" as="geometry"/>
        </mxCell>
        
        <!-- Arrow 7-8 -->
        <mxCell id="arrow7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6c8ebf;endArrow=block;endFill=1" edge="1" parent="1" source="step7" target="step8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Output Box -->
        <mxCell id="output" value="Результаты:&#xa;&#xa;• Таблицы 3.1-3.8&#xa;• Рисунки 3.1-3.8&#xa;• Корреляционная матрица&#xa;• Статистическая значимость&#xa;• Рекомендации по выбору метода" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingTop=5;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="250" y="490" width="390" height="110" as="geometry"/>
