              <mxPoint x="260" y="755" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="linear_label" value="α=0 (линейная)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#999999" vertex="1" parent="1">
          <mxGeometry x="220" y="790" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="curve_02_label" value="α=0.2" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#1a73e8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="180" y="730" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="curve_10_label" value="α=1.0" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#d79b00;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="760" width="40" height="20" as="geometry" />
