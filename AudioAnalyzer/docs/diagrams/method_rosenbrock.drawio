        <mxCell id="use_title" value="🎯 Где применять" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="640" width="300" height="30" as="geometry" />
