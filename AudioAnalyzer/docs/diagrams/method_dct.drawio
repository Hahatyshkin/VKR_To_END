  <diagram id="method-dct" name="Метод DCT (ГОСТ 19.701-90)">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="840" pageHeight="1188" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок по ГОСТ -->
        <mxCell id="header" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="50" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Метод DCT — Дискретное косинусное преобразование&#xa;Лист 1 из 1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="25" width="760" height="40" as="geometry" />
        </mxCell>
        
        <!-- Начало -->
        <mxCell id="start" value="Начало" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="370" y="90" width="100" height="35" as="geometry" />
        </mxCell>
        
        <!-- Вход -->
        <mxCell id="p1" value="Вход: аудиосигнал&#xa;x[n], n = 0..N-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#000000;strokeWidth=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="140" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="a1" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="start" target="p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- OLA разбиение -->
        <mxCell id="p2" value="Разбиение на блоки&#xa;(Overlap-Add)&#xa;с окном Ханна" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#000000;strokeWidth=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="350" y="220" width="140" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="a2" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p1" target="p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Цикл -->
        <mxCell id="d1" value="Цикл по&#xa;блокам?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="370" y="300" width="100" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="a3" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p2" target="d1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- DCT-II -->
        <mxCell id="p3" value="Прямое DCT-II:&#xa;X[k] = Σ x[n]·cos(πk(2n+1)/2N)&#xa;Вещественные коэффициенты" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#000000;strokeWidth=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="350" y="390" width="140" height="55" as="geometry" />
        </mxCell>
        
        <mxCell id="a4" value="Да" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="d1" target="p3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Отбор -->
        <mxCell id="p4" value="Отбор коэффициентов:&#xa;• energy (95% энергии)&#xa;• lowpass (НЧ)&#xa;• none (все)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#000000;strokeWidth=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="350" y="470" width="140" height="65" as="geometry" />
        </mxCell>
        
        <mxCell id="a5" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p3" target="p4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- IDCT -->
        <mxCell id="p5" value="Обратное IDCT-III:&#xa;x'[n] = Σ X[k]·cos(πk(2n+1)/2N)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#000000;strokeWidth=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="350" y="560" width="140" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="a6" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p4" target="p5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Возврат -->
        <mxCell id="a7" value="След." style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1;dashed=1" edge="1" parent="1" source="p5" target="d1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="585" />
              <mxPoint x="280" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- OLA сборка -->
        <mxCell id="p6" value="Восстановление&#xa;сигнала (OLA)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#000000;strokeWidth=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="350" y="640" width="140" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="a8" value="Все" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="d1" target="p6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="330" />
              <mxPoint x="560" y="665" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Выход -->
        <mxCell id="p7" value="Выход:&#xa;обработанный сигнал" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#000000;strokeWidth=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="350" y="710" width="140" height="45" as="geometry" />
        </mxCell>
        
        <mxCell id="a9" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p6" target="p7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Конец -->
        <mxCell id="end" value="Конец" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="370" y="780" width="100" height="35" as="geometry" />
        </mxCell>
        
        <mxCell id="a10" style="endArrow=block;html=1;strokeWidth=1;strokeColor=#000000;endFill=1" edge="1" parent="1" source="p7" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Формулы (справа) -->
        <mxCell id="formula_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="220" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="formula_title" value="Формула DCT-II:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="155" width="150" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="formula" value="X[k] = c(k)·Σ x[n]·cos(πk(2n+1)/2N)&#xa;&#xa;где c(0)=√(1/N), c(k)=√(2/N)&#xa;&#xa;Особенности:&#xa;• Только вещественные числа&#xa;• Симметричное расширение&#xa;• Концентрация энергии в первых&#xa;  коэффициентах" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="570" y="175" width="200" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="props_title" value="Преимущества:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="280" width="100" height="15" as="geometry" />
        </mxCell>
        
        <mxCell id="props" value="• Стандарт MP3, AAC, JPEG&#xa;• 90% энергии в 5-10% коэффициентов&#xa;• Нет комплексных чисел" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="570" y="295" width="200" height="45" as="geometry" />
        </mxCell>
        
        <!-- Применение -->
        <mxCell id="use_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="560" y="350" width="220" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="use_title" value="Применение:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="355" width="100" height="15" as="geometry" />
        </mxCell>
        
        <mxCell id="use_text" value="• MP3 и AAC кодирование&#xa;• JPEG сжатие изображений&#xa;• Сжатие с потерями качества&#xa;• Стандарт индустрии" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="570" y="370" width="200" height="55" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
